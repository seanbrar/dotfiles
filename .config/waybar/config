{
    // Adapted from Egosummiki's waybar config

    "layer": "top", // Waybar at top layer
    "position": "top", // Waybar at the bottom of your screen
    "height": 24, // Waybar height
    // "width": 1366, // Waybar width
    // Choose the order of the modules
    "modules-left": ["sway/workspaces", "sway/mode", "custom/separator", "custom/spotify"],
    "modules-center": ["sway/window"],
    "modules-right": [
        "pulseaudio",
        "custom/separator",
        "custom/weather",
        "custom/separator",
        "cpu",
        "custom/separator",
        "memory",
        "custom/separator",
        "battery",
        "custom/separator",
        "idle_inhibitor",
        "custom/separator",
        "custom/updates",
        "custom/separator",
        "tray",
        "custom/separator",
        "clock"
    ],
    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": false,
        "format": "{icon}",
        "format-icons": {
            "1:web": "юЭЕ",
            "2:code": "яДб",
            "3:term": "яДа",
            "4:work": "яДе",
            "5:music": "яАе",
            "6:docs": "яЬЩ",
            "urgent": "яБк",
            "focused": "яЖТ",
            "default": "яДС"
        }
    },
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "tray": {
        // "icon-size": 21,
        "spacing": 10
    },
    "clock": {
        "format": "{:%I:%M %p | %a, %b %d}"
//  Uncomment to include abriged day of the week
//        "format-alt": "{:%a %m-%d-%Y}"
//        "format-alt": "{:%m-%d-%Y}"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "яБо",
            "deactivated": "яБ░"
        }
    },
    "cpu": {
        "format": "{usage}% <span font=\"FontAwesome 5 Free Solid\">яЛЫ</span>"
    },
    "memory": {
        "format": "{}% <span font=\"FontAwesome 5 Free Solid\">яГЙ</span>"
    },
    "battery": {
        "bat": "BAT0",
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
    },
    // network removed from "modules-right"
    "network": {
        // "interface": "wlp2s0", // (Optional) To force the use of this interface
        "format-wifi": "{essid} ({signalStrength}%) яЗл",
        "format-ethernet": "{ifname}: {ipaddr}/{cidr} <span font=\"FontAwesome 5 Free Solid\">яГБ</span>",
        "format-disconnected": "Disconnected тЪа"
    },
    // mpd removed from "modules-right"
    "mpd": {
        "format": "{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}{artist} - {album} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S}) яАБ",
        "format-disconnected": "Disconnected яАБ",
        "format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped яАБ",
        "unknown-tag": "N/A",
        "interval": 2,
        "consume-icons": {
            "on": "яГД "
        },
        "random-icons": {
            "off": "<span color=\"#f53c3c\">яБ┤</span> ",
            "on": "яБ┤ "
        },
        "repeat-icons": {
            "on": "яАЮ "
        },
        "single-icons": {
            "on": "<span font=\"FontAwesome 5 Free Solid\">яАЮ</span>1 "
        },
        "state-icons": {
            "paused": "<span font=\"FontAwesome 5 Free Solid\">яБМ</span>",
            "playing": "<span font=\"FontAwesome 5 Free Solid\">яБЛ</span>"
        },
        "tooltip-format": "MPD (connected)",
        "tooltip-format-disconnected": "MPD (disconnected)"
    },
    "custom/weather": {
        "format": "<span font=\"FontAwesome 5 Free Solid\">{}</span>",
        "format-alt": "{alt}: <span font=\"FontAwesome 5 Free Solid\">{}</span>",
        "format-alt-click": "click-right",
        "interval": 1800,
        "return-type": "json",
        "exec": "~/.config/waybar/modules/weather.sh",
        "exec-if": "ping wttr.in -c1"
    },
    "pulseaudio": {
        //"scroll-step": 1,
        "format": "{volume}% {icon}",
        "format-bluetooth": "{volume}% {icon}яКФ",
        "format-muted": "яАж",
        "format-icons": {
            "headphones": "яАе",
            "handsfree": "яЦР",
            "headset": "яЦР",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": ["<span font=\"FontAwesome 5 Free Solid\">яАз</span>", "<span font=\"FontAwesome 5 Free Solid\">яАи</span>"]
            //"default": ["яАз", "<span font=\"FontAwesome 5 Free Solid\">яАи</span>"]
        },
        "on-click": "pavucontrol"
    },
    "custom/spotify": {
        "format": "яЖ╝ {}",
        "max-length": 40,
        "interval": 30, // Remove this if your script is endless and write in loop
        "exec": "$HOME/.config/waybar/mediaplayer.sh 2> /dev/null", // Script in resources folder
        "exec-if": "pgrep spotify"
    },
    "custom/updates": {
        "format": "{} ",
        "interval": 3600,
        "exec": "checkupdates | wc -l",
        "exec-if": "exit 0",
        "on-click": "alacritty -e sudo pacman -Syu",
        "signal": 8
    },
    "custom/separator": {
        "format": "|",
        "interval": "once",
        "tooltip": false
    }
}
